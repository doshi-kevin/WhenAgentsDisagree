# LLM Provider API Keys (all free tier, no credit card needed)
GROQ_API_KEY=gsk_xxxxxxxxxxxx
CEREBRAS_API_KEY=csk-xxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/experiments.db

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# Debate Defaults
DEFAULT_MAX_ROUNDS=3
DEFAULT_MAX_TURNS_PER_ROUND=3
DEADLOCK_SIMILARITY_THRESHOLD=0.90

# Metrics
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
